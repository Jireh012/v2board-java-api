<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.v2board.api.mapper.UserMapper">

    <!--
      批量更新用户流量：使用 CASE 语句一次 SQL 更新所有用户的 u/d/t/updated_at
      对齐 PHP traffic:update 命令中的 bulk UPDATE
    -->
    <update id="batchUpdateTraffic">
        UPDATE v2_user
        SET
            u = u + CASE id
                <foreach collection="trafficMap" index="userId" item="traffic">
                    WHEN #{userId} THEN #{traffic[0]}
                </foreach>
                ELSE 0
            END,
            d = d + CASE id
                <foreach collection="trafficMap" index="userId" item="traffic">
                    WHEN #{userId} THEN #{traffic[1]}
                </foreach>
                ELSE 0
            END,
            t = #{timestamp},
            updated_at = #{timestamp}
        WHERE id IN
        <foreach collection="trafficMap" index="userId" item="traffic"
                 open="(" separator="," close=")">
            #{userId}
        </foreach>
    </update>

</mapper>
